{
  "include": [
    ".github/scripts",
    ".github/scripts/npm_publish",
    ".github/scripts/tests"
  ],
  "extraPaths": [".github/scripts", ".github/scripts/npm_publish"],
  "executionEnvironments": [
    {
      "root": ".github/scripts",
